#!/usr/bin/env bash
# Release MCP launcher (Linux). Resolves its own real location (works when
# invoked via a PATH symlink), points LGX_BIN at the bundled binary, starts ts-mcp.
HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
export LD_LIBRARY_PATH="$HERE/bin${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LGX_BIN="${LGX_BIN:-$HERE/bin/legixy}"
exec node "$HERE/ts-mcp/dist/index.js" "$@"
