#!/usr/bin/env bash
# Release MCP launcher (Linux). Points LGX_BIN at the bundled binary and
# makes the bundled ONNX Runtime loadable, then starts the ts-mcp server.
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export LD_LIBRARY_PATH="$HERE/bin${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LGX_BIN="${LGX_BIN:-$HERE/bin/legixy}"
exec node "$HERE/ts-mcp/dist/index.js" "$@"
